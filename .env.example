AWS_REGION=us-east-1
PHOTOGALLERY_S3_BUCKET_NAME=replace-with-bucket-name
SES_EMAIL_SOURCE=verified-sender@example.com
SQL_FLASK_KEY=replace-with-a-long-random-secret
NOSQL_FLASK_KEY=replace-with-a-different-long-random-secret
SQL_PUBLIC_BASE_URL=http://localhost:5000
NOSQL_PUBLIC_BASE_URL=http://localhost:5001
RDS_DB_HOSTNAME=replace-with-rds-endpoint
